# block 1

bg_color white
set ray_opaque_background, 1
set antialias, 2
set depth_cue, 1
set fog_start, 0.45
set ray_shadow, 1
set cartoon_fancy_helices, 1
set cartoon_smooth_loops, 1
set cartoon_highlight_color, grey70
set stick_radius, 0.15
set sphere_scale, 0.35
set label_size, 14
set label_color, black

# block 2
fetch 1u19, bRho,    async=0
fetch 2rh1, beta2AR, async=0
fetch 4dkl, muOR,    async=0
fetch 3eml, A2AR,    async=0
fetch 4djh, kappaOR, async=0

