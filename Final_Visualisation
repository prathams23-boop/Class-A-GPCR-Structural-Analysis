# block 9
select beta2AR_CCM, beta2AR and resi 155+158+164+166
show sticks, beta2AR_CCM
color tv_yellow, beta2AR_CCM

# block 10
# Each receptor's lipid contacts computed independently.
# This is the correct approach — each receptor's lipids
# only query that receptor's own protein residues.
# These five receptors do not physically co-exist;
# the alignment in Block 15 is visual only.

select bRho_annular,    byres (bRho_lipids_all    expand 5.0) and bRho    and polymer and chain A
select beta2AR_annular, byres (beta2AR_lipids_all expand 5.0) and beta2AR and polymer and chain A
select muOR_annular,    byres (muOR_lipids_all    expand 5.0) and muOR    and polymer and chain A
select A2AR_annular,    byres (A2AR_lipids_all    expand 5.0) and A2AR    and polymer and chain A
select kappaOR_annular, byres (kappaOR_lipids_all expand 5.0) and kappaOR and polymer and chain A

show sticks, bRho_annular
show sticks, beta2AR_annular
show sticks, muOR_annular
show sticks, A2AR_annular
show sticks, kappaOR_annular

# block 11
select bRho_PLM_contacts, byres (bRho_lipids_all expand 5.0) and bRho and polymer and chain A
show sticks, bRho_PLM_contacts
color limon, bRho_PLM_contacts
print "=== bRho: residues contacting palmitic acid (PLM) ==="
iterate bRho_PLM_contacts, print("  resi %s  resn %s" % (resi, resn))

# block 12

# Atom names verified by iterate on 2RH1 chain A:
# Trp158 indole nitrogen = NE1 (standard amino acid naming)
# Cholesterol hydroxyl oxygen = O1 (confirmed from iterate)
# O3 does not exist in this structure — that was the error.

# --- Step 1: final atom verification before measuring ---
print "=== Confirming Trp158 NE1 ==="
iterate beta2AR and resi 158 and name NE1 and chain A, print("  found: resi %s  resn %s  atom %s" % (resi, resn, name))
# Must print exactly one line showing TRP 158 NE1
# If nothing prints, run: iterate beta2AR and resi 158, print(name)
# to find the exact nitrogen atom name in your structure

print "=== Confirming CLR oxygen name = O1 ==="
iterate beta2AR and resn CLR and name O1 and chain A, print("  found: resi %s  resn %s  atom %s" % (resi, resn, name))
# Must print three lines — one for each CLR 412, 413, 414

# --- Step 3: measure W158 NE1 to O1 of each cholesterol ---
distance beta2AR_W158_to_CLR412, /beta2AR//A/158/NE1, /beta2AR//A/412/O1
distance beta2AR_W158_to_CLR413, /beta2AR//A/158/NE1, /beta2AR//A/413/O1
distance beta2AR_W158_to_CLR414, /beta2AR//A/158/NE1, /beta2AR//A/414/O1
# CLR 412 = CCM site on TM4 — this should be the short one
# CLR 413, 414 = TM1-TM2-H8 groove — these will be longer

# --- Step 4: make lines visible ---
color yellow, beta2AR_W158_to_CLR412
color grey70, beta2AR_W158_to_CLR413
color grey70, beta2AR_W158_to_CLR414
set dash_width, 4
set dash_radius, 0.08
set label_size, 18

# --- Step 5: zoom to see the full CCM interaction site ---
zoom beta2AR and resi 155+158+164+166+412+413+414
# This frames the CCM residues and all three cholesterols
# together so all three distance lines are visible at once

print "=== Block 12 complete ==="
print "=== CLR 412 line is yellow  — expect ~3.2-4.0 A  ==="
print "=== CLR 413 and 414 are grey — expect > 8 A      ==="

# block 13
# Polar contact sweep between beta2AR protein and lipids.
# Identifies all potential hydrogen bonds and electrostatic
# contacts between the receptor and its co-crystallised
# cholesterol (CLR 412, 413, 414) and palmitic acid (PLM 415).
#
# Scientific basis: cholesterol has only one polar atom (O1,
# the hydroxyl oxygen confirmed by iterate in Block 12).
# Expecting few formal H-bonds — cholesterol binding is
# primarily hydrophobic. The single Trp158-CLR412 contact
# measured in Block 12 is likely the only formal H-bond.
# Reference: Hanson et al. 2008, Structure 16:897

# --- define selections explicitly on chain A only ---
select beta2AR_protein_atoms, beta2AR and polymer and chain A
select beta2AR_all_lipid_atoms, beta2AR and resn CLR+PLM and chain A

# --- verify lipid polar atoms are present ---
print "=== beta2AR lipid polar atoms (O and N only) ==="
iterate beta2AR_all_lipid_atoms and elem O+N, print("  resi %s  resn %s  atom %s" % (resi, resn, name))
# Expected output — verified by iterate on 2RH1 chain A:
#   resi 412  resn CLR  atom O1  (cholesterol hydroxyl)
#   resi 413  resn CLR  atom O1  (cholesterol hydroxyl)
#   resi 414  resn CLR  atom O1  (cholesterol hydroxyl)
#   resi 415  resn PLM  atom O2  (palmitic acid — single oxygen)
# Note: PLM 415 has only one oxygen (O2), not a standard
# carboxylate pair. Maximum possible H-bonds = 4.
# If this prints correctly your selections are good.
# If PLM oxygens do not appear, palmitic acid may use
# different oxygen names — adjust elem filter accordingly.

# --- primary measurement: formal hydrogen bonds at 3.5 A ---
distance beta2AR_hbonds_3p5, beta2AR_protein_atoms, beta2AR_all_lipid_atoms, 3.5, mode=2
color blue, beta2AR_hbonds_3p5
set dash_width, 3
set dash_radius, 0.06
set label_size, 16

# --- optional: weaker polar contacts at 4.5 A ---
# Uncomment if you want to see CH...O type contacts as well
# distance beta2AR_hbonds_4p5, beta2AR_protein_atoms, beta2AR_all_lipid_atoms, 4.5, mode=2
# color cyan, beta2AR_hbonds_4p5

# --- optional: full electrostatic range at 5.0 A ---
# Uncomment to see all electrostatic interactions
# distance beta2AR_hbonds_5p0, beta2AR_protein_atoms, beta2AR_all_lipid_atoms, 5.0, mode=2
# color teal, beta2AR_hbonds_5p0

# --- zoom to lipid region to see all lines ---
zoom beta2AR and resn CLR+PLM
# Centres the view on all lipid molecules so every
# contact line is visible in the same frame

print "=== Block 13 complete ==="
print "=== Blue dashed lines = H-bonds within 3.5 A     ==="
print "=== If only 1 line: confirms cholesterol binding  ==="
print "=== is primarily hydrophobic with single H-bond   ==="
print "=== anchor at Trp158 — consistent with Hanson 2008 ==="

# block 14
create bRho_surface_obj, bRho and polymer
show surface, bRho_surface_obj
spectrum b, blue_white_red, bRho_surface_obj
set transparency, 0.4, bRho_surface_obj

# block 15
align beta2AR, bRho
align muOR,    bRho
align A2AR,    bRho

# kappaOR is a homodimer — align chain A only against bRho
# otherwise the dimer confuses the alignment algorithm

create kappaOR_chainA, kappaOR and chain A
align kappaOR_chainA, bRho

